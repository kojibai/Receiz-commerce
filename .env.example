# Required: Receiz production rails. Receiz proof objects are the system of record.
NEXT_PUBLIC_RECEIZ_MODE=live
RECEIZ_BASE_URL=https://receiz.com
RECEIZ_CLIENT_ID=
RECEIZ_CLIENT_SECRET=

# Required: Receiz ID / OIDC callback.
NEXT_PUBLIC_AUTH_MODE=receiz_id
RECEIZ_AUTH_MODE=receiz_id
RECEIZ_ID_CALLBACK_URL=https://receiz.app/api/auth/receiz/callback
NEXT_PUBLIC_SITE_URL=https://receiz.app

# Required when live checkout is enabled. The user access token is generated by OIDC login.
NEXT_PUBLIC_CHECKOUT_MODE=receiz
RECEIZ_CHECKOUT_MODE=receiz

# Optional hosted-commerce product settings.
NEXT_PUBLIC_HOSTING_MODE=receiz_hosted
NEXT_PUBLIC_DEFAULT_SUBDOMAIN=boost.receiz.app
RECEIZ_ACCOUNT_STATE_MODE=receiz

# Optional webhook secrets, if Receiz webhooks are enabled for this app.
RECEIZ_WEBHOOK_SECRET=
RECEIZ_CHECKOUT_WEBHOOK_SECRET=
RECEIZ_PROOF_WEBHOOK_SECRET=
RECEIZ_HOSTING_WEBHOOK_SECRET=

# Optional if Vercel is the deployment/domain automation layer.
VERCEL_TEAM_ID=
VERCEL_TEAM_SLUG=
VERCEL_PROJECT_ID=
VERCEL_API_TOKEN=
VERCEL_CNAME_TARGET=cname.vercel-dns-0.com
VERCEL_APEX_A_RECORD=76.76.21.21

# Receiz settlement for platform hosting/custom-domain fees we collect.
# Set live only when RECEIZ_PLATFORM_ACCOUNT_ID is your Receiz account/user id.
RECEIZ_PLATFORM_BILLING_MODE=sandbox
RECEIZ_PLATFORM_ACCOUNT_ID=
RECEIZ_PRO_PLAN_USD=49.00
RECEIZ_SCALE_PLAN_USD=199.00
RECEIZ_CUSTOM_DOMAIN_SETUP_USD=0.00

# Optional default merchant settlement fallback for demo checkout.
RECEIZ_DEFAULT_MERCHANT_RECEIZ_ID=
RECEIZ_DEFAULT_SETTLEMENT_USER_ID=

# Receiz plan identifiers for hosted commerce upgrades, if your Receiz account exposes plans.
RECEIZ_CUSTOM_DOMAIN_PLAN_ID=
RECEIZ_HOSTING_PRO_PLAN_ID=

# Optional experimental content assistance.
# Keep unset until @receiz/sdk exposes the typed Receiz Twin/World namespace for production use.
NEXT_PUBLIC_RECEIZ_TWIN_ENABLED=false
NEXT_PUBLIC_RECEIZ_WORLD_ENABLED=false

# Do not set these for normal login. OIDC creates per-user access tokens at callback time.
# Optional only if Receiz explicitly issues a static app-level/service token.
# Normal OIDC login generates per-user access tokens at callback time.
# RECEIZ_ACCESS_TOKEN=
# RECEIZ_CONNECT_ACCESS_TOKEN=
