{
  "name": "receiz-commerce-kit",
  "version": "0.1.0",
  "description": "Open-source Receiz SDK commerce SaaS template for proof-sealed storefronts, rewards, checkout, domains, and admin builders.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "keywords": [
    "receiz",
    "commerce",
    "ecommerce",
    "nextjs",
    "proof-objects",
    "receiz-sdk",
    "rewards"
  ],
  "packageManager": "pnpm@10.29.1",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "node scripts/next-runtime-guard.mjs dev",
    "build": "node scripts/next-runtime-guard.mjs build",
    "start": "node scripts/next-runtime-guard.mjs start",
    "test": "tsc -p tsconfig.test.json && node scripts/patch-test-imports.mjs && node --test .test-build/tests/*.test.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "receiz:doctor": "node scripts/receiz-doctor.mjs",
    "release:check": "node scripts/release-check.mjs"
  },
  "dependencies": {
    "@receiz/sdk": "^97.6.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.6.0"
  }
}
