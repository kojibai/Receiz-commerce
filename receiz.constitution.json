{
  "schema": "receiz.constitution.registry.v1",
  "version": "110.0.0",
  "previousRegistryDigest": "824aa4af849c4840ba94535798eab36e45d514703b6ae0cd30d4aa53f3c896e4",
  "effectiveKai": "13185897",
  "createdAt": "2026-07-18T09:10:00.000Z",
  "laws": [
    {
      "id": "wilds.retirement.irreversible",
      "version": 1,
      "phases": ["command", "merge", "migration"],
      "denyWhen": { "op": "transition", "path": "life", "from": "dead", "to": "alive" },
      "denial": { "code": "RETIREMENT_IS_FINAL", "safeAlternatives": ["memorialize", "retire", "create-descendant"] }
    },
    {
      "id": "authority.tenant.explicit",
      "version": 1,
      "phases": ["command", "admission"],
      "denyWhen": { "op": "not", "value": { "op": "path", "value": "tenant.id" } },
      "denial": { "code": "TENANT_REQUIRED", "safeAlternatives": ["bind-tenant"] }
    },
    {
      "id": "receiz.command-only-mutation",
      "version": 1,
      "phases": ["command", "event", "merge", "migration", "admission"],
      "denyWhen": {
        "op": "not",
        "value": { "op": "equal", "left": { "op": "path", "value": "mutation.mode" }, "right": { "op": "literal", "value": "admitted-command" } }
      },
      "denial": { "code": "DIRECT_STATE_WRITE_FORBIDDEN", "safeAlternatives": ["define-command", "simulate-command", "request-capability"] }
    },
    {
      "id": "identity.profile.same-account-uid",
      "version": 1,
      "phases": ["command", "admission", "migration"],
      "denyWhen": {
        "op": "not",
        "value": {
          "op": "equal",
          "left": { "op": "path", "value": "actor.accountUid" },
          "right": { "op": "path", "value": "proposed.accountUid" }
        }
      },
      "denial": { "code": "PROFILE_ACCOUNT_UID_MISMATCH", "safeAlternatives": ["use-authenticated-account-uid", "restore-receiz-identity"] }
    },
    {
      "id": "artifact.complete-object-custody",
      "version": 1,
      "phases": ["command", "admission"],
      "denyWhen": { "op": "not", "value": { "op": "path", "value": "artifact.complete" } },
      "denial": { "code": "COMPLETE_ARTIFACT_REQUIRED", "safeAlternatives": ["preserve-complete-sealed-artifact", "verify-before-extract"] }
    },
    {
      "id": "ARTIFACT-011",
      "version": 1,
      "phases": ["command", "admission", "merge"],
      "denyWhen": {
        "op": "all",
        "values": [
          {
            "op": "equal",
            "left": { "op": "path", "value": "operation.kind" },
            "right": { "op": "literal", "value": "sdk-artifact-verify-or-open" }
          },
          {
            "op": "path",
            "value": "operation.requiresWeakerState"
          }
        ]
      },
      "denial": {
        "code": "LOCAL_ARTIFACT_VERIFICATION_MUST_NOT_REQUIRE_WEAKER_STATE",
        "safeAlternatives": ["verify-complete-artifact-bytes-locally", "discover-verified-additions-after-local-verdict"]
      }
    },
    {
      "id": "ARTIFACT-012",
      "version": 1,
      "phases": ["admission"],
      "denyWhen": {
        "op": "all",
        "values": [
          {
            "op": "equal",
            "left": { "op": "path", "value": "operation.kind" },
            "right": { "op": "literal", "value": "artifact-admit" }
          },
          {
            "op": "any",
            "values": [
              {
                "op": "not",
                "value": {
                  "op": "equal",
                  "left": { "op": "path", "value": "evidence.completeArtifactBytesVerified" },
                  "right": { "op": "literal", "value": true }
                }
              },
              {
                "op": "equal",
                "left": { "op": "path", "value": "proposed.payloadClassifiedBeforeArtifactVerification" },
                "right": { "op": "literal", "value": true }
              }
            ]
          }
        ]
      },
      "denial": {
        "code": "COMPLETE_ARTIFACT_ADMISSION_REQUIRED",
        "safeAlternatives": ["verify-exact-enclosing-artifact-bytes", "classify-only-after-verification"]
      }
    },
    {
      "id": "ARTIFACT-013",
      "version": 1,
      "phases": ["command", "admission"],
      "denyWhen": {
        "op": "all",
        "values": [
          {
            "op": "equal",
            "left": { "op": "path", "value": "admission.verdict" },
            "right": { "op": "literal", "value": "bearer-recovery" }
          },
          {
            "op": "any",
            "values": [
              { "op": "equal", "left": { "op": "path", "value": "proposed.canSign" }, "right": { "op": "literal", "value": true } },
              { "op": "equal", "left": { "op": "path", "value": "proposed.canPublish" }, "right": { "op": "literal", "value": true } },
              { "op": "equal", "left": { "op": "path", "value": "proposed.canSettle" }, "right": { "op": "literal", "value": true } },
              { "op": "equal", "left": { "op": "path", "value": "proposed.canonicalIdentityAuthority" }, "right": { "op": "literal", "value": true } }
            ]
          }
        ]
      },
      "denial": {
        "code": "BEARER_AUTHORITY_ESCALATION_FORBIDDEN",
        "safeAlternatives": ["require-verified-claimant-capability", "retain-explicit-permitted-actions"]
      }
    },
    {
      "id": "ARTIFACT-014",
      "version": 1,
      "phases": ["command", "admission"],
      "denyWhen": {
        "op": "all",
        "values": [
          {
            "op": "equal",
            "left": { "op": "path", "value": "operation.kind" },
            "right": { "op": "literal", "value": "artifact-recovery-commit" }
          },
          {
            "op": "any",
            "values": [
              { "op": "not", "value": { "op": "equal", "left": { "op": "path", "value": "evidence.sdkIssuedPlan" }, "right": { "op": "literal", "value": true } } },
              { "op": "not", "value": { "op": "equal", "left": { "op": "path", "value": "evidence.verifiedCapability" }, "right": { "op": "literal", "value": true } } },
              { "op": "not", "value": { "op": "equal", "left": { "op": "path", "value": "evidence.stableIdempotencyKey" }, "right": { "op": "literal", "value": true } } },
              { "op": "not", "value": { "op": "equal", "left": { "op": "path", "value": "proposed.atomicUnitOfWork" }, "right": { "op": "literal", "value": true } } }
            ]
          }
        ]
      },
      "denial": {
        "code": "ATOMIC_CAPABILITY_RECOVERY_COMMIT_REQUIRED",
        "safeAlternatives": ["use-sdk-issued-recovery-plan", "verify-capability", "commit-one-atomic-unit-of-work"]
      }
    },
    {
      "id": "ARTIFACT-015",
      "version": 1,
      "phases": ["command", "admission", "merge"],
      "denyWhen": {
        "op": "equal",
        "left": { "op": "path", "value": "proposed.explanationIsProofAuthority" },
        "right": { "op": "literal", "value": true }
      },
      "denial": {
        "code": "PROOF_EXPLANATION_NOT_AUTHORITY",
        "safeAlternatives": ["use-bounded-explanation-as-non-authoritative-projection", "retain-underlying-proof-object-as-authority"]
      }
    },
    {
      "id": "ownership.enclosing-artifact-first",
      "version": 1,
      "phases": ["command", "admission"],
      "denyWhen": {
        "op": "not",
        "value": {
          "op": "equal",
          "left": { "op": "path", "value": "artifact.enclosingProofVerified" },
          "right": { "op": "literal", "value": true }
        }
      },
      "denial": { "code": "ENCLOSING_ARTIFACT_PROOF_REQUIRED", "safeAlternatives": ["verify-enclosing-artifact-then-claim"] }
    },
    {
      "id": "offline.queued-not-committed",
      "version": 1,
      "phases": ["command", "admission", "migration"],
      "denyWhen": {
        "op": "all",
        "values": [
          {
            "op": "equal",
            "left": { "op": "path", "value": "proposed.status" },
            "right": { "op": "literal", "value": "queued" }
          },
          {
            "op": "equal",
            "left": { "op": "path", "value": "proposed.globallyCommitted" },
            "right": { "op": "literal", "value": true }
          }
        ]
      },
      "denial": { "code": "QUEUED_COMMAND_NOT_COMMITTED", "safeAlternatives": ["report-signed-queued-proposal", "resume-canonical-admission"] }
    },
    {
      "id": "migration.witnessed-history-immutable",
      "version": 1,
      "phases": ["migration"],
      "denyWhen": {
        "op": "equal",
        "left": { "op": "path", "value": "migration.historyRewritten" },
        "right": { "op": "literal", "value": true }
      },
      "denial": { "code": "WITNESSED_HISTORY_REWRITE_FORBIDDEN", "safeAlternatives": ["roll-forward-from-verified-checkpoint"] }
    }
  ],
  "authority": { "registryPayloadIsAuthority": false, "strongerTruth": "sealed-receiz-proof-object" }
}
